# 飞书应用凭证
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# LLM 配置（默认使用 Kimi K2.5）
LLM_ENDPOINT=https://api.moonshot.cn/v1
LLM_API_KEY=
LLM_MODEL=kimi-k2.5

# SQLite 数据库路径
SQLITE_PATH=./data/okr-agent.db

# 用户来源方式 1：手动指定用户 ID 列表（逗号分隔）
OKR_USER_IDS=ou_xxx,ou_yyy

# 用户来源方式 2：通过飞书部门 ID 动态获取成员（逗号分隔，可与上面同时使用）
FEISHU_DEPARTMENT_IDS=od_xxx

# Cron 表达式，默认每周一上午 9 点
CRON_SCHEDULE=0 9 * * 1
