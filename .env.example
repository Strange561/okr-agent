# 飞书应用凭证
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Azure OpenAI 配置
AZURE_OPENAI_ENDPOINT=https://你的资源名.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# SQLite 数据库路径
SQLITE_PATH=./data/okr-agent.db

# 用户来源方式 1：手动指定用户 ID 列表（逗号分隔）
OKR_USER_IDS=ou_xxx,ou_yyy

# 用户来源方式 2：通过飞书部门 ID 动态获取成员（逗号分隔，可与上面同时使用）
FEISHU_DEPARTMENT_IDS=od_xxx

# Cron 表达式，默认每周一上午 9 点
CRON_SCHEDULE=0 9 * * 1
